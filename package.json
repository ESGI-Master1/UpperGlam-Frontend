    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~55.0.12",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
