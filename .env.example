# App Environment
EXPO_PUBLIC_APP_ENV=development

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3333
EXPO_PUBLIC_REQUEST_TIMEOUT_MS=10000
EXPO_PUBLIC_PRE_REGISTRATION_URL=https://upperglam.fr

# Feature Flags
EXPO_PUBLIC_USE_MOCK_DATA=false

# Analytics (PostHog)
EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
EXPO_PUBLIC_ANALYTICS_DEVICE_PEPPER=change_me_per_environment
# Optional compatibility fallback (if existing setup still uses Vite keys)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
